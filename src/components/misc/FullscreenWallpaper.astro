---
import { siteConfig } from "../../config";
import type { FullscreenWallpaperConfig } from "../../types/config";

interface Props {
	config: FullscreenWallpaperConfig;
	className?: string;
}

const { config, className } = Astro.props;

// 获取静态配置的图片源（API调用移到客户端）
const getImageSources = () => {
	let srcConfig = config.src;

	const toArray = (src: string | string[] | undefined): string[] => 
		Array.isArray(src) ? src : (typeof src === "string" ? [src] : []);

	if (typeof srcConfig === "object" && srcConfig !== null && !Array.isArray(srcConfig)) {
		const desktop = toArray(srcConfig.desktop);
		const mobile = toArray(srcConfig.mobile);
		return {
			desktop: desktop.length > 0 ? desktop : mobile,
			mobile: mobile.length > 0 ? mobile : desktop,
		};
	}

	const allImages = toArray(srcConfig as string | string[]);
	return { desktop: allImages, mobile: allImages };
};

const staticImageSources = getImageSources();

// API 配置
const imageApiConfig = siteConfig.banner.imageApi;
const isApiEnabled = imageApiConfig?.enable && imageApiConfig?.url;

// 轮播配置
const carouselInterval = config.carousel?.interval || 5;

// 样式配置
const position = config.position || "center";
const zIndex = config.zIndex || -1;
const opacity = config.opacity || 0.8;
const blurAmount = config.blur || 0;
const positionClass = (() => {
	switch (position) {
		case "top": return "object-top";
		case "bottom": return "object-bottom";
		default: return "object-center";
	}
})();
---

<div 
	class:list={[
		"fixed inset-0 w-full h-full overflow-hidden pointer-events-none",
		className
	]}
	style={`z-index: ${zIndex}; opacity: ${opacity}; transform: translateZ(0); perspective: 1000px;`}
	data-fullscreen-wallpaper
>
	<script is:inline>
	(function() {
		const checkMode = () => {
			const mode = localStorage.getItem('wallpaperMode') || 'banner';
			const container = document.currentScript.parentElement;
			if (mode !== 'fullscreen') {
				container.style.display = 'none';
			} else {
				container.style.display = '';
			}
		};
		checkMode();
		// 监听 localStorage 变化，实时更新显示状态
		window.addEventListener('storage', (e) => {
			if (e.key === 'wallpaperMode') {
				checkMode();
			}
		});
	})();
	</script>

	<div id="wallpaper-container" class="w-full h-full relative" style="background: var(--page-bg);">
		<script is:inline define:vars={{ 
			apiConfig: imageApiConfig, 
			staticImages: staticImageSources, 
			positionClass, 
			blurAmount,
			carouselInterval
		}}>
		(async function() {
			const container = document.getElementById('wallpaper-container');
			
			// 从 API 或静态配置获取图片
			let desktopImages = staticImages.desktop || [];
			let mobileImages = staticImages.mobile || [];
			
			// 如果启用了 API，则从 API 获取图片
			if (apiConfig?.enable && apiConfig?.url) {
				try {
					// 添加随机参数，确保每次获取不同的图片
					const randomParam = `&_t=${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
					const apiUrl = apiConfig.url + (apiConfig.url.includes('?') ? '&' : '?') + randomParam;
					const response = await fetch(apiUrl);
					const text = await response.text();
					const apiImages = text.split("\n")
						.map(line => line.trim())
						.filter(line => line.length > 0)
						.map(url => url.replace(/\/+/g, '/').replace(':/', '://')); // 修复双斜杠问题
					if (apiImages.length > 0) {
						// 从返回的图片中随机选择一张
						const randomIndex = Math.floor(Math.random() * apiImages.length);
						const randomImage = apiImages[randomIndex];
						desktopImages = [randomImage];
						mobileImages = [randomImage];
					}
				} catch (error) {
					console.warn('Failed to fetch images from API:', error);
				}
			}
			
			// 如果没有图片，直接返回
			if (desktopImages.length === 0 && mobileImages.length === 0) {
				return;
			}
			
			// 随机选择一张图片
			const getRandomImage = (images, storageKey) => {
				if (images.length === 0) return null;
				if (images.length === 1) return images[0];
				
				const lastIndex = sessionStorage.getItem(storageKey);
				let newIndex;
				
				do {
					newIndex = Math.floor(Math.random() * images.length);
				} while (newIndex === parseInt(lastIndex || '-1'));
				
				sessionStorage.setItem(storageKey, newIndex.toString());
				return images[newIndex];
			};
			
			const desktopSrc = getRandomImage(desktopImages, 'wallpaper_desktop_index');
			const mobileSrc = getRandomImage(mobileImages, 'wallpaper_mobile_index');
			
			// 创建桌面端图片
			if (desktopSrc) {
				const desktopDiv = document.createElement('div');
				desktopDiv.className = 'hidden md:block w-full h-full relative';
				desktopDiv.style.transform = 'translateZ(0)';
				const img = document.createElement('img');
				img.src = desktopSrc;
				img.alt = '';
				img.className = `absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${positionClass}`;
				img.style.cssText = `transform: translateZ(0); backface-visibility: hidden; will-change: opacity; ${blurAmount > 0 ? `filter: blur(${blurAmount}px);` : ''} opacity: 0;`;
				img.decoding = 'async';
				img.loading = 'eager';
				img.onload = function() { this.style.opacity = '1'; };
				img.onerror = function() { 
					console.warn('Failed to load desktop wallpaper:', desktopSrc);
					this.style.opacity = '0';
				};
				desktopDiv.appendChild(img);
				container.appendChild(desktopDiv);
			}
			
			// 创建移动端图片
			if (mobileSrc) {
				const mobileDiv = document.createElement('div');
				mobileDiv.className = 'block md:hidden w-full h-full relative';
				mobileDiv.style.transform = 'translateZ(0)';
				const img = document.createElement('img');
				img.src = mobileSrc;
				img.alt = '';
				img.className = `absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${positionClass}`;
				img.style.cssText = `transform: translateZ(0); backface-visibility: hidden; will-change: opacity; ${blurAmount > 0 ? `filter: blur(${blurAmount}px);` : ''} opacity: 0;`;
				img.decoding = 'async';
				img.loading = 'eager';
				img.onload = function() { this.style.opacity = '1'; };
				img.onerror = function() { 
					console.warn('Failed to load mobile wallpaper:', mobileSrc);
					this.style.opacity = '0';
				};
				mobileDiv.appendChild(img);
				container.appendChild(mobileDiv);
			}
		})();
		</script>
	</div>
</div>
